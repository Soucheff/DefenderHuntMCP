# Single-tenant Entra resource API and OBO configuration
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_MCP_AUDIENCE=api://00000000-0000-0000-0000-000000000000
ENTRA_MCP_ISSUER=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000/v2.0
ENTRA_MCP_USER_SCOPE=Mcp.Access
ENTRA_MCP_AGENT_ROLE=Mcp.Invoke

# Local OBO confidential credential. Production should use a Key Vault-backed certificate.
AZURE_CLIENT_SECRET=replace-with-local-development-secret
# AZURE_CLIENT_CERTIFICATE_PATH=/run/secrets/obo-certificate.pem

# User-assigned identity used for autonomous Graph calls and Azure Managed Redis.
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# Server runtime
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Host port published by compose.yaml; does not change PORT inside the container.
MCP_PORT=8000
REDIS_PORT=6379

# Local cache settings. Azure uses Azure Managed Redis with Entra authentication.
CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=defender-hunt:dev
REDIS_HOST=
REDIS_ENTRA_USERNAME=

# Microsoft Graph beta agent-governance adapter.
ENABLE_AGENT_GOVERNANCE_BETA=false

# Comma-separated browser origins, for example https://soc.example.com.
# Leave empty for non-browser MCP clients and to disable CORS middleware.
ALLOWED_ORIGINS=