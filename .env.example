# Microsoft Graph application credentials (required)
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=replace-with-client-secret

# MCP client authentication. Required for any externally reachable deployment.
MCP_API_KEY=replace-with-a-long-random-value

# Server runtime
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Host port published by compose.yaml; does not change PORT inside the container.
MCP_PORT=8000

# Comma-separated browser origins, for example https://soc.example.com.
# Leave empty for non-browser MCP clients and to disable CORS middleware.
ALLOWED_ORIGINS=